# PostgreSQL
DATABASE_URL="postgresql://grantchina:grantchina@localhost:5432/grantchina?schema=public"

# Server
PORT=3001

# JWT — для сотрудников CRM
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Отдельный JWT для студентов (опционально). Если не задан — используется JWT_SECRET (legacy fallback).
# Рекомендуется: задать длинную случайную строку, отличную от JWT_SECRET.
STUDENT_JWT_SECRET=""

# CORS — список фронтендов через запятую
CORS_ORIGINS="http://localhost:5173,http://localhost:5174"

# Загрузка файлов
UPLOADS_DIR="./uploads"
MAX_FILE_SIZE=209715200

# Telegram бот @grant_chinabot (опционально).
# Получить токен у @BotFather.
TELEGRAM_BOT_TOKEN=""

# TELEGRAM_CHAT_ID — личный чат / группа администраторов, куда бот шлёт
# уведомления о новых заявках с лендинга. ID можно узнать у @userinfobot.
TELEGRAM_CHAT_ID=""

# TELEGRAM_CHANNEL_ID — публичный канал @grant_china_tj, куда бот
# автоматически постит карточки программ. Бот должен быть админом канала.
# Формат: "@grant_china_tj" или числовой ID -100xxxx.
TELEGRAM_CHANNEL_ID=""

# PUBLIC_API_BASE — внешний URL бэкенда, нужен Telegram-каналу чтобы
# подгрузить картинку программы (например https://grantchina-production.up.railway.app)
PUBLIC_API_BASE=""

# SMTP для email-уведомлений (опционально)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="GrantChina CRM <noreply@grantchina.local>"
ADMIN_EMAIL=""

# SMS-уведомления (опционально). SMS_PROVIDER = "payom" | "smsru" | "twilio" | пусто (отключено)
SMS_PROVIDER=""

# Payom.tj — таджикский SMS-шлюз. https://payom.tj/
# Берётся в личном кабинете → API → Bearer token + senderName (max 11 латиницей)
PAYOM_API_URL="https://gateway.payom.tj"
PAYOM_TOKEN=""
PAYOM_SENDER=""

# SMS.ru — глобальный провайдер для RU/CIS. https://sms.ru → Settings → API → API ID
SMSRU_API_ID=""
SMS_FROM=""

# Twilio — глобальный провайдер. https://console.twilio.com
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""
