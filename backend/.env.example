# PostgreSQL
DATABASE_URL="postgresql://grantchina:grantchina@localhost:5432/grantchina?schema=public"

# Server
PORT=3001

# JWT
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# CORS — список фронтендов через запятую
CORS_ORIGINS="http://localhost:5173,http://localhost:5174"

# Загрузка файлов
UPLOADS_DIR="./uploads"
MAX_FILE_SIZE=10485760

# Telegram (опционально). Получить токен у @BotFather, ID чата у @userinfobot
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# SMTP для email-уведомлений (опционально)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="GrantChina CRM <noreply@grantchina.local>"
ADMIN_EMAIL=""

# SMS-уведомления (опционально). SMS_PROVIDER = "smsru" | "twilio" | пусто (отключено)
SMS_PROVIDER=""

# SMS.ru — рекомендуемый провайдер для CIS / Таджикистан.
# Регистрация: https://sms.ru → Settings → API → API ID
SMSRU_API_ID=""
SMS_FROM=""

# Twilio — глобальный провайдер. https://console.twilio.com
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""
