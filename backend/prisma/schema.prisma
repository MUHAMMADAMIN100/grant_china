generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum Direction {
  BACHELOR
  MASTER
  LANGUAGE
}

enum ApplicationStatus {
  NEW
  IN_PROGRESS
  COMPLETED
}

enum StudentStatus {
  ACTIVE
  PAUSED
  GRADUATED
  ARCHIVED
}

enum TaskStatus {
  TODO
  DONE
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  fullName   String
  role       Role     @default(EMPLOYEE)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  notifications      Notification[]
  managedApplications Application[] @relation("ApplicationManager")
  managedStudents    Student[]     @relation("StudentManager")
  assignedTasks      Task[]        @relation("TaskAssignee")
  createdTasks       Task[]        @relation("TaskCreator")
}

model Application {
  id         String            @id @default(uuid())
  fullName   String
  phone      String
  email      String?
  direction  Direction
  comment    String?
  status     ApplicationStatus @default(NEW)
  studentId  String?
  student    Student?          @relation(fields: [studentId], references: [id])
  managerId  String?
  manager    User?             @relation("ApplicationManager", fields: [managerId], references: [id], onDelete: SetNull)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([status])
  @@index([direction])
  @@index([managerId])
}

model Student {
  id           String        @id @default(uuid())
  fullName     String
  phones       String[]      @default([])
  email        String?
  photoUrl     String?
  direction    Direction
  cabinet      Int
  status       StudentStatus @default(ACTIVE)
  comment      String?
  managerId    String?
  manager      User?         @relation("StudentManager", fields: [managerId], references: [id], onDelete: SetNull)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  documents    Document[]
  applications Application[]

  @@index([direction])
  @@index([cabinet])
  @@index([status])
  @@index([managerId])
}

model Document {
  id         String   @id @default(uuid())
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  filename   String
  originalName String
  mimeType   String
  size       Int
  url        String
  type       String   @default("OTHER")
  createdAt  DateTime @default(now())

  @@index([studentId, type])
}

model Task {
  id           String     @id @default(uuid())
  title        String
  description  String
  status       TaskStatus @default(TODO)
  assignedToId String
  assignedTo   User       @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: Cascade)
  createdById  String?
  createdBy    User?      @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([assignedToId])
  @@index([status])
}

model Notification {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String   // "APPLICATION_NEW", "APPLICATION_DELAY", etc.
  title      String
  message    String
  payload    Json?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId, read])
  @@index([createdAt])
}
