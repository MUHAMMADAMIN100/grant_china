generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum Direction {
  BACHELOR
  MASTER
  LANGUAGE
}

enum ApplicationStatus {
  NEW
  IN_PROGRESS      // legacy → DOCS_REVIEW
  COMPLETED        // legacy → ENROLLED
  DOCS_REVIEW
  DOCS_SUBMITTED
  PRE_ADMISSION
  AWAITING_PAYMENT
  ENROLLED
}

enum StudentStatus {
  ACTIVE
  PAUSED
  GRADUATED
  ARCHIVED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  fullName   String
  role       Role     @default(EMPLOYEE)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  notifications      Notification[]
  managedApplications      Application[] @relation("ApplicationManager")
  managedChinaApplications Application[] @relation("ApplicationChinaManager")
  managedStudents          Student[]     @relation("StudentManager")
  managedChinaStudents     Student[]     @relation("StudentChinaManager")
  assignedTasks            Task[]        @relation("TaskAssignee")
  createdTasks             Task[]        @relation("TaskCreator")
}

model Application {
  id         String            @id @default(uuid())
  fullName   String
  phone      String
  email      String?
  direction  Direction
  comment    String?
  status     ApplicationStatus @default(NEW)
  studentId  String?
  student    Student?          @relation(fields: [studentId], references: [id])
  managerId       String?
  manager         User?             @relation("ApplicationManager", fields: [managerId], references: [id], onDelete: SetNull)
  chinaManagerId  String?
  chinaManager    User?             @relation("ApplicationChinaManager", fields: [chinaManagerId], references: [id], onDelete: SetNull)
  programId       String?
  program         Program?          @relation(fields: [programId], references: [id], onDelete: SetNull)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([status])
  @@index([direction])
  @@index([managerId])
  @@index([chinaManagerId])
  @@index([programId])
}

model Student {
  id           String        @id @default(uuid())
  fullName     String
  phones       String[]      @default([])
  email           String?
  password        String?
  applicationForm Json?
  photoUrl        String?
  direction    Direction
  cabinet      Int
  status       StudentStatus @default(ACTIVE)
  comment      String?
  managerId         String?
  manager           User?         @relation("StudentManager", fields: [managerId], references: [id], onDelete: SetNull)
  chinaManagerId    String?
  chinaManager      User?         @relation("StudentChinaManager", fields: [chinaManagerId], references: [id], onDelete: SetNull)
  programId         String?
  program           Program?      @relation(fields: [programId], references: [id], onDelete: SetNull)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  documents    Document[]
  applications Application[]

  @@index([direction])
  @@index([cabinet])
  @@index([status])
  @@index([managerId])
  @@index([chinaManagerId])
  @@index([programId])
}

model Document {
  id         String   @id @default(uuid())
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  filename   String
  originalName String
  mimeType   String
  size       Int
  url        String
  type       String   @default("OTHER")
  createdAt  DateTime @default(now())

  @@index([studentId, type])
}

model Task {
  id           String     @id @default(uuid())
  title        String
  description  String
  status       TaskStatus @default(TODO)
  assignedToId String
  assignedTo   User       @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: Cascade)
  createdById  String?
  createdBy    User?      @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([assignedToId])
  @@index([status])
}

model Program {
  id           String    @id @default(uuid())
  name         String
  university   String
  city         String
  major        String
  direction    Direction
  cost         Float
  currency     String    @default("CNY")
  duration     String?
  language     String?
  description  String?
  imageUrl     String?
  published    Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  applications Application[]
  students     Student[]

  @@index([city])
  @@index([major])
  @@index([direction])
  @@index([published])
}

model Notification {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String   // "APPLICATION_NEW", "APPLICATION_DELAY", etc.
  title      String
  message    String
  payload    Json?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId, read])
  @@index([createdAt])
}
