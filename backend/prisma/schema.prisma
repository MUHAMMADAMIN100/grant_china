generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum Direction {
  BACHELOR
  MASTER
  LANGUAGE
  LANGUAGE_COLLEGE
  LANGUAGE_BACHELOR
  COLLEGE
}

enum ApplicationStatus {
  NEW
  IN_PROGRESS      // legacy → DOCS_REVIEW
  COMPLETED        // legacy → ENROLLED
  DOCS_REVIEW
  DOCS_SUBMITTED
  PRE_ADMISSION
  AWAITING_PAYMENT
  ENROLLED
}

enum StudentStatus {
  ACTIVE
  PAUSED
  GRADUATED
  ARCHIVED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  fullName   String
  role       Role     @default(EMPLOYEE)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  notifications      Notification[]
  managedApplications      Application[] @relation("ApplicationManager")
  managedChinaApplications Application[] @relation("ApplicationChinaManager")
  managedStudents          Student[]     @relation("StudentManager")
  managedChinaStudents     Student[]     @relation("StudentChinaManager")
  assignedTasks            Task[]        @relation("TaskAssignee")
  createdTasks             Task[]        @relation("TaskCreator")
}

// Заявка на обучение: создаётся через лендинг (POST /applications/public),
// либо автоматически вместе со студентом из CRM ("+ Студент").
// При удалении любого из связанных объектов (User-менеджер, Program) заявка
// остаётся в БД с обнулённой ссылкой (SetNull) — историю не теряем.
// При удалении Student — Application НЕ удаляется автоматически
// (нет onDelete: Cascade на student-связи), поэтому в applications.service.remove()
// студент явно удаляется отдельно.
model Application {
  id         String            @id @default(uuid())
  fullName   String
  phone      String
  email      String?
  direction  Direction
  comment    String?
  status     ApplicationStatus @default(NEW)
  studentId  String?
  // student → SetNull-семантика по сути не задана, потому что removed применяется в коде вручную.
  student    Student?          @relation(fields: [studentId], references: [id])
  managerId       String?
  // Удалили сотрудника-менеджера TJ → менеджер у заявки обнуляется, заявка остаётся.
  manager         User?             @relation("ApplicationManager", fields: [managerId], references: [id], onDelete: SetNull)
  chinaManagerId  String?
  // Аналогично для китайского менеджера.
  chinaManager    User?             @relation("ApplicationChinaManager", fields: [chinaManagerId], references: [id], onDelete: SetNull)
  programId       String?
  // Удалили программу → у заявки programId становится null.
  program         Program?          @relation(fields: [programId], references: [id], onDelete: SetNull)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([status])
  @@index([direction])
  @@index([managerId])
  @@index([chinaManagerId])
  @@index([programId])
}

model Student {
  id           String        @id @default(uuid())
  fullName     String
  phones       String[]      @default([])
  email           String?
  password        String?
  applicationForm Json?
  photoUrl        String?
  direction    Direction
  cabinet      Int
  status       StudentStatus @default(ACTIVE)
  comment      String?
  managerId         String?
  manager           User?         @relation("StudentManager", fields: [managerId], references: [id], onDelete: SetNull)
  chinaManagerId    String?
  chinaManager      User?         @relation("StudentChinaManager", fields: [chinaManagerId], references: [id], onDelete: SetNull)
  programId         String?
  program           Program?      @relation(fields: [programId], references: [id], onDelete: SetNull)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  documents    Document[]
  applications Application[]

  @@index([direction])
  @@index([cabinet])
  @@index([status])
  @@index([managerId])
  @@index([chinaManagerId])
  @@index([programId])
}

// Документ студента (10 типов + OTHER).
// При удалении студента документы каскадно удаляются (Cascade) — это сейчас
// единственная Cascade-связь в схеме. Заявки и менеджеры используют SetNull.
model Document {
  id         String   @id @default(uuid())
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  filename   String
  originalName String
  mimeType   String
  size       Int
  url        String
  type       String   @default("OTHER")
  createdAt  DateTime @default(now())

  @@index([studentId, type])
}

model Task {
  id           String     @id @default(uuid())
  title        String
  description  String
  status       TaskStatus @default(TODO)
  assignedToId String
  assignedTo   User       @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: Cascade)
  createdById  String?
  createdBy    User?      @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([assignedToId])
  @@index([status])
}

model Program {
  id                 String    @id @default(uuid())
  name               String
  university         String
  city               String
  major              String
  direction          Direction
  cost               Float
  currency           String    @default("CNY")
  duration           String?
  language           String?
  description        String?
  imageUrl           String?
  published          Boolean   @default(true)
  telegramMessageId  Int?
  telegramHasPhoto   Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  applications Application[]
  students     Student[]

  @@index([city])
  @@index([major])
  @@index([direction])
  @@index([published])
}

model Notification {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String   // "APPLICATION_NEW", "APPLICATION_DELAY", etc.
  title      String
  message    String
  payload    Json?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId, read])
  @@index([createdAt])
}

model ActivityLog {
  id          String   @id @default(uuid())
  actorId     String?
  actorName   String
  actorRole   String   // ADMIN | EMPLOYEE
  action      String   // "STATUS_CHANGE" | "STUDENT_UPDATE" | "MANAGER_CHANGE" | "STUDENT_CREATE" | "STUDENT_DELETE"
  studentId   String?
  studentName String?
  details     String   // human-readable: "Статус: NEW → DOCS_REVIEW", "Менеджер TJ: A → B"
  payload     Json?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([studentId])
  @@index([actorId])
}
