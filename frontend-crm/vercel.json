{
  "redirects": [
    { "source": "/", "destination": "/admin", "permanent": false }
  ],
  "rewrites": [
    { "source": "/admin/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/admin/(.+\\.[a-zA-Z0-9]+)", "destination": "/$1" },
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/admin/(.*)", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
